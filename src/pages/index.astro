---
// src/pages/index.astro
// Importamos tus datos base (español por defecto)
import settings from '../data/settings.json';
import portada from '../data/portada.json';
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  
  <title>{settings.title}</title>
  <meta name="description" content={settings.description}>
  <meta name="keywords" content={settings.keywords}>

  <!-- Open Graph / Redes Sociales (Facebook, WhatsApp) -->
  <meta property="og:type" content="website">
  <meta property="og:title" content={settings.title}>
  <meta property="og:description" content={settings.description}>
  <meta property="og:image" content={new URL(portada.image, Astro.url)}>
  <meta property="og:url" content={Astro.url}>

  <!-- Twitter Card -->
  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:url" content={Astro.url} />
  <meta property="twitter:title" content={settings.title} />
  <meta property="twitter:description" content={settings.description} />
  <meta property="twitter:image" content={new URL(portada.image, Astro.url)} />

  <!-- hreflang para Google -->
  <link rel="alternate" hreflang="es" href={new URL('/es/', Astro.url)} />
  <link rel="alternate" hreflang="en" href={new URL('/en/', Astro.url)} />
  <link rel="alternate" hreflang="x-default" href={new URL('/es/', Astro.url)} />

  <!-- Redirección para navegadores antiguos -->
  <meta http-equiv="refresh" content="0;url=/es/" />

  <script>
    // Detecta el idioma del navegador del usuario
    const userLang = navigator.language || navigator.userLanguage;
    
    // Si su navegador está en inglés, mándalo a /en/, si no, a /es/
    if (userLang.startsWith('en')) {
      window.location.replace('/en/');
    } else {
      window.location.replace('/es/');
    }
  </script>
</head>
<body>
  <p>Redirigiendo a <a href="/es/">la página principal...</a></p>
</body>
</html>