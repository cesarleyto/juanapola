---
/* src/pages/[lang]/blog/index.astro */
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import blogSettings from '../../../data/blog-settings.json';

export async function getStaticPaths() {
  return [{ params: { lang: 'es' } }, { params: { lang: 'en' } }];
}

const { lang } = Astro.params;

const blogTitle = blogSettings?.title || "Nuestro Blog";
const blogDesc = blogSettings?.description || "Explora nuestras últimas noticias y artículos.";

const allPosts = await getCollection('blog');
// FILTRO DINÁMICO: usa el parámetro de la URL
const posts = allPosts.filter((post: any) => post.id.startsWith(`${lang}/`));

posts.sort((a: any, b: any) => {
  const dateA = a.data.pubDate ? new Date(a.data.pubDate).valueOf() : 0;
  const dateB = b.data.pubDate ? new Date(b.data.pubDate).valueOf() : 0;
  return dateB - dateA;
});

const categories = [...new Set(posts.map((post: any) => post.data.category).filter(Boolean))];

// Traducción rápida para la UI
const t = {
  todos: lang === 'en' ? 'All' : 'Todos',
  leerMas: lang === 'en' ? 'Read more' : 'Leer más'
};
---

<Layout title={blogTitle} description={blogDesc}>
  <div class="page-container" style="max-width: 1200px; margin: 7rem auto 5rem; padding: 0 1.5rem;">
    <header style="text-align: center; margin-bottom: 4rem;">
      <h1 style="font-size: clamp(2.5rem, 5vw, 3.5rem); margin-bottom: 1rem;">{blogTitle}</h1>
      <p style="font-size: 1.1rem; opacity: 0.8; max-width: 600px; margin: 0 auto;">{blogDesc}</p>
    </header>

    <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; margin-bottom: 4rem;">
      <button class="btn-principal filter-btn" data-filter="all">{t.todos}</button>
      {categories.map((cat: any) => (
        <button class="btn-outline filter-btn" data-filter={cat}>{cat}</button>
      ))}
    </div>

    <div class="blog-grid" id="blogGrid">
      {posts.map((post: any) => {
        // Limpiamos el prefijo de idioma para la URL
        const slugReal = post.id.replace(`${lang}/`, '').replace(/\.md$/, '');
        return (
          <a href={`/${lang}/blog/${slugReal}`} class="blog-card fondo-default" data-category={post.data.category || 'Sin Categoría'}>
            <div class="card-image-wrapper">
              {post.data.category && <span class="card-badge tag-mono">{post.data.category}</span>}
              {post.data.heroImage ? (
                <img src={post.data.heroImage} alt={post.data.title} class="card-img" />
              ) : (
                <div class="card-placeholder fondo-acento"></div>
              )}
            </div>
            <div class="card-content">
              <h3>{post.data.title}</h3>
              <p>{post.data.description}</p>
              <span class="leer-mas">{t.leerMas} &rarr;</span>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</Layout>

<script>
  const filterBtns = document.querySelectorAll('.filter-btn');
  const cards = document.querySelectorAll('.blog-card');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const filterValue = btn.getAttribute('data-filter');

      filterBtns.forEach(b => {
        b.classList.remove('btn-principal');
        b.classList.add('btn-outline');
      });

      btn.classList.remove('btn-outline');
      btn.classList.add('btn-principal');

      cards.forEach(card => {
        const cardCategory = card.getAttribute('data-category');
        
        if (filterValue === 'all' || filterValue === cardCategory) {
          (card as HTMLElement).style.display = 'flex';
          setTimeout(() => (card as HTMLElement).style.opacity = '1', 10);
        } else {
          (card as HTMLElement).style.opacity = '0';
          setTimeout(() => (card as HTMLElement).style.display = 'none', 300);
        }
      });
    });
  });
</script>

<style>
  .blog-grid { display: flex; flex-direction: column; gap: 3.5rem; width: 100%; }
  .blog-card { display: flex; flex-direction: column; border-radius: var(--radius-card, 24px); overflow: hidden; text-decoration: none; box-shadow: 0 10px 30px rgba(0,0,0,0.05); transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.3s ease, opacity 0.3s ease; opacity: 1; width: 100%; }
  .blog-card:hover { transform: scale(1.015); box-shadow: 0 20px 40px rgba(0,0,0,0.08); }
  .card-image-wrapper { position: relative; width: 100%; aspect-ratio: 3 / 2; overflow: hidden; }
  .card-img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease; }
  .blog-card:hover .card-img { transform: scale(1.06); }
  .card-placeholder { width: 100%; height: 100%; }
  .card-badge { position: absolute; top: 1.5rem; left: 1.5rem; background-color: var(--color-acento2, #000); color: var(--texto-color-acento2, #fff); padding: 0.5rem 1.2rem; border-radius: var(--radius-capsule, 50px); z-index: 10; }
  .card-content { padding: 2rem; display: flex; flex-direction: column; flex: 1; justify-content: center; }
  .card-content h3 { margin-bottom: 1rem; font-size: 1.4rem; color: var(--titulos-default-color, #000); }
  .card-content p { opacity: 0.75; font-size: 1rem; line-height: 1.6; margin-bottom: 2rem; color: var(--texto-default-color, #000); }
  .leer-mas { text-align: right; font-family: var(--font-mono); font-weight: 700; font-size: 0.85rem; text-transform: uppercase; color: var(--titulos-default-color, #000); margin-top: auto; }
  @media (min-width: 769px) {
    .blog-card { flex-direction: row; align-items: stretch; }
    .card-image-wrapper { width: 45%; min-width: 400px; aspect-ratio: auto; height: auto; }
    .card-img { position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; }
    .card-content { padding: 3rem 4rem; justify-content: center; }
  }
</style>