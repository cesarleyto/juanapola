---
/* src/layouts/Layout.astro */
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
    title?: string;
    description?: string;
    image?: string;
}

const { title, description, image } = Astro.props;

// 1. Detectamos el idioma actual por la URL
const pathname = Astro.url.pathname;
const lang = pathname.startsWith('/en') ? 'en' : 'es';

// 2. Importamos los settings del idioma correspondiente
const settingsFiles = import.meta.glob('../data/settings*.json', { eager: true });
const settingsObj = (settingsFiles[`../data/settings-${lang}.json`] || settingsFiles['../data/settings.json']) as any;
const settings = settingsObj.default || settingsObj;

// 3. Construimos el título exacto sin que se duplique
const finalTitle = title ? `${title} | ${settings.title}` : settings.title;
const finalDescription = description || settings.description;
---

<!doctype html>
<html lang={lang}>
    <head>
        <BaseHead title={finalTitle} description={finalDescription} image={image} />
    </head>
    <body style="min-height: 100vh; display: flex; flex-direction: column;">
        <Header />
        <main style="flex: 1;">
            <slot />
        </main>
        <Footer />
    </body>
</html>